# Dev server (npm run dev / start — avoids :3000 used by Scriptony & others)
PORT=3047

# Content provider (default: json files in content/)
# CONTENT_PROVIDER=json
# CONTENT_PROVIDER=supabase
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Tutor LLM — pick one provider (Ollama recommended for local-first)

# --- Ollama local (default when no keys set) ---
# Run: ollama serve && ollama pull llama3.2
# TUTOR_LLM_BASE_URL=http://localhost:11434/v1
# TUTOR_MODEL=llama3.2

# --- Ollama Cloud (https://ollama.com) ---
# TUTOR_LLM_BASE_URL=https://ollama.com/v1
# OLLAMA_API_KEY=
# TUTOR_MODEL=llama3.2

# --- OpenAI (legacy, still supported) ---
# OPENAI_API_KEY=
# TUTOR_MODEL=gpt-4o-mini

# Optional overrides (any provider)
# TUTOR_LLM_API_KEY=
# TUTOR_DAILY_LIMIT=20
