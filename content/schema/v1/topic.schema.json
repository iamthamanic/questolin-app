{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://questolin.app/content/schema/v1/topic.schema.json",
  "title": "Questolin Topic v1",
  "description": "Ein Lern-Thema mit geordneten Slides. Neue Themen = neue JSON-Datei, kein Code-Change.",
  "type": "object",
  "required": ["schemaVersion", "id", "title", "category", "locale", "slides"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "category": { "type": "string" },
    "locale": { "type": "string", "pattern": "^[a-z]{2}$" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "difficulty": { "enum": ["beginner", "intermediate", "advanced"] },
    "estimatedMinutes": { "type": "number", "minimum": 1 },
    "prerequisites": { "type": "array", "items": { "type": "string" } },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/slide" }
    }
  },
  "$defs": {
    "slideType": {
      "type": "string",
      "enum": [
        "hook",
        "explanation",
        "real_world",
        "scenario",
        "beginner_mistake",
        "quiz",
        "code_read",
        "code_fix"
      ]
    },
    "slide": {
      "type": "object",
      "required": ["id", "type", "order", "content"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "type": { "$ref": "#/$defs/slideType" },
        "order": { "type": "integer", "minimum": 0 },
        "title": { "type": "string" },
        "content": { "type": "object" }
      }
    }
  }
}
